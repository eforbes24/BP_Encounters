Cell[BoxData[{
 RowBox[{
  RowBox[{"gran", " ", "=", "1"}], ";", " ", 
  RowBox[{"min", " ", "=", " ", "1"}], ";", " ", 
  RowBox[{"max", " ", "=", " ", "31"}], ";", " ", 
  RowBox[{"ZD", "=", 
   RowBox[{"List", "[", "]"}]}], ";", 
  RowBox[{"EINTD", " ", "=", " ", 
   RowBox[{"List", "[", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", 
    RowBox[{"min", "/", "gran"}]}], ",", 
   RowBox[{"i", "<=", 
    RowBox[{"max", "/", "gran"}]}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zmax", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Maximize", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Re", "[", 
             RowBox[{"EINT", "[", 
              RowBox[{
               RowBox[{"i", "*", "gran"}], ",", " ", "0.01", ",", " ", "1", ",",
                " ", "z", ",", " ", "z", ",", " ", "5"}], "]"}], "]"}], ",", 
            RowBox[{"z", ">", "0"}]}], "}"}], ",", "z"}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"ZD", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"i", "*", "gran"}], ",", "zmax"}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"EINTD", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"i", "*", "gran"}], ",", 
        RowBox[{"EINT", "[", 
         RowBox[{
          RowBox[{"i", "*", "gran"}], ",", "0.01", ",", " ", "1", ",", " ", 
          "zmax", ",", " ", "zmax", ",", " ", "5"}], "]"}]}], "}"}]}], "]"}], 
    ";"}]}], "\[IndentingNewLine]", "]"}]}], "Input",
