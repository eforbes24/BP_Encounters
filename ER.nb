Cell[BoxData[{
 RowBox[{
  RowBox[{"gran", " ", "=", " ", "0.1"}], ";", " ", 
  RowBox[{"min", " ", "=", " ", "0"}], ";", " ", 
  RowBox[{"max", " ", "=", " ", "3"}], ";", " ", 
  RowBox[{"ZU", "=", 
   RowBox[{"List", "[", "]"}]}], ";", " ", 
  RowBox[{"EINTU", " ", "=", " ", 
   RowBox[{"List", "[", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", 
    RowBox[{"min", "/", "gran"}]}], ",", 
   RowBox[{"i", "<=", 
    RowBox[{"max", "/", "gran"}]}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zmax", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Maximize", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Re", "[", 
             RowBox[{"EINT", "[", 
              RowBox[{"30", ",", " ", "0.01", ",", " ", 
               RowBox[{"i", "*", "gran"}], ",", " ", "z", ",", " ", "z", ",", 
               " ", "5"}], "]"}], "]"}], ",", 
            RowBox[{"z", ">", "0"}]}], "}"}], ",", "z"}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"ZU", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"i", "*", "gran"}], ",", "zmax"}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"EINTU", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"i", "*", "gran"}], ",", 
        RowBox[{"EINT", "[", 
         RowBox[{"30", ",", "0.01", ",", " ", 
          RowBox[{"i", "*", "gran"}], ",", " ", "zmax", ",", " ", "zmax", ",",
           " ", "5"}], "]"}]}], "}"}]}], "]"}], ";"}]}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
 CellChangeTimes->{{3.9846519657647*^9, 3.984651984016176*^9}, {
   3.984652038109009*^9, 3.984652216995926*^9}, 3.9846523899796066`*^9, 
