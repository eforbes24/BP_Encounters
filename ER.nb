Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"M2Do", "[", 
    RowBox[{"dens_", ",", " ", "v_", ",", "u_", ",", "rad_"}], "]"}], ":=", 
   RowBox[{
    FractionBox["1", "\[Pi]"], "2", " ", "dens", " ", "rad", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SqrtBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"u", "-", "v"}], ")"}], "2"]], " ", 
       RowBox[{"EllipticE", "[", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{"4", " ", "u", " ", "v"}], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"u", "-", "v"}], ")"}], "2"]]}], "]"}]}], "+", 
      RowBox[{
       SqrtBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"u", "+", "v"}], ")"}], "2"]], " ", 
       RowBox[{"EllipticE", "[", 
        FractionBox[
         RowBox[{"4", " ", "u", " ", "v"}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"u", "+", "v"}], ")"}], "2"]], "]"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"M3Do", "[", 
    RowBox[{"dens_", ",", "v_", ",", "u_", ",", "rad_"}], "]"}], ":=", "  ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"\[Pi]", " ", 
           SuperscriptBox["rad", "2"], " ", "dens"}], "3"], 
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            SuperscriptBox["u", "2"], "+", 
            RowBox[{"3", 
             SuperscriptBox["v", "2"]}]}], "v"], ")"}]}], ",", " ", 
        RowBox[{"u", "<", "v"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"\[Pi]", " ", 
           SuperscriptBox["rad", "2"], " ", "dens"}], "3"], 
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            SuperscriptBox["v", "2"], "+", 
            RowBox[{"3", 
             SuperscriptBox["u", "2"]}]}], "u"], ")"}]}], ",", " ", 
        RowBox[{"u", " ", ">=", " ", "v"}]}], "}"}]}], "}"}], "]"}]}], 
  ";"}]}], "Input",
